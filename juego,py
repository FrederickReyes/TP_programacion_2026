import random

usuario_registrado = ""
contrasena_registrada = ""
puntaje = 0

while True:

    print("\n= MENU PRINCIPAL =")
    print("1. Registrarse")
    print("2. Iniciar sesión")
    print("3. Salir")

    opcion = input("Seleccione una opción: ")

    if opcion == "1":

        usuario_registrado = input("Ingrese un nombre: ")
        contrasena_registrada = input("Ingrese una contraseña: ")

        print("Registro exitoso")

    elif opcion == "2":

        usuario = input("Usuario: ")
        contrasena = input("Contraseña: ")

        if usuario == usuario_registrado and contrasena == contrasena_registrada:

            print("Inicio de sesión correcto")

            while True:

                print("\n= AHORCADO =")
                print("1. Jugar")
                print("2. Ver puntaje")
                print("3. Cerrar sesión")

                opcion_juego = input("Seleccione una opción: ")

                if opcion_juego == "1":

                    palabras = ["python", "juego", "codigo"]
                    palabra = random.choice(palabras)

                    intentos = 6
                    adivinada = ""

                    while intentos > 0:

                        print("\nPalabra:", adivinada)

                        letra = input("Ingrese una letra: ")

                        if letra in palabra:

                            adivinada = adivinada + letra

                            if len(adivinada) >= len(palabra):

                                print("Ganaste")
                                puntaje += 1
                                break

                        else:

                            intentos -= 1
                            print("Letra incorrecta")
                            print("Intentos restantes:", intentos)

                    if intentos == 0:
                        print("Perdiste")
                        print("La palabra era:", palabra)

                elif opcion_juego == "2":

                    print("Puntaje:", puntaje)

                elif opcion_juego == "3":

                    print("Sesión cerrada")
                    break

                else:

                    print("Opción incorrecta")

        else:

            print("Usuario o contraseña incorrectos")

    elif opcion == "3":

        print("Programa finalizado")
        break

    else:

        print("Opción incorrecta")
